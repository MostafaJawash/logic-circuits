# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# admin access-code lists contain PLAINTEXT codes — keep them out of the repo.
# (data/accessCodes.json stores only hashes and IS safe to commit.)
/access-codes.txt
/access-codes.csv

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
